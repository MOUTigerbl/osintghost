from telegram import Update, InlineKeyboardButton, InlineKeyboardMarkup
from telegram.ext import Application, CommandHandler, CallbackQueryHandler, ContextTypes

# Токен бота
TOKEN = "8627452726:AAGV7R-5SIrCUKVLFabag6gp8g_0TF5aZNs"

# ID пользователя, которому будут отправляться заявки (указываем без @)
TARGET_USER = "oxaul"

# Каталог товаров
PRODUCTS = {
    "shocker": {"name": "Шокер", "price": 600},
    "knife": {"name": "Нож", "price": 400},
    "flamethrower": {"name": "Огнемет", "price": 300}
}

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Обработчик команды /start — показывает главное меню с товарами."""
    keyboard = [
        [InlineKeyboardButton(f"{PRODUCTS[key]['name']} — {PRODUCTS[key]['price']}₽", callback_data=key)]
        for key in PRODUCTS
    ]
    reply_markup = InlineKeyboardMarkup(keyboard)
    await update.message.reply_text("Добро пожаловать в магазин! Выберите товар:", reply_markup=reply_markup)

async def button_handler(update: Update, context: ContextTypes.DEFAULT_TYPE) -> None:
    """Обработчик нажатий на кнопки товаров."""
    query = update.callback_query
    await query.answer()

    product_key = query.data
    product = PRODUCTS[product_key]

    # Формируем сообщение для отправки целевому пользователю
    user = query.from_user
    message_text = (
        f"🛒 Новая заявка на заказ!\n"
        f"Пользователь: {user.full_name} (@{user.username or 'нет юзернейма'})\n"
        f"Товар: {product['name']}\n"
        f"Цена: {product['price']}₽"
    )

    try:
        # Отправляем сообщение в ЛС пользователю @oxaul
        await context.bot.send_message(chat_id=f"@{TARGET_USER}", text=message_text)
        await query.edit_message_text(text=f"✅ Ваша заявка на {product['name']} отправлена!")
    except Exception as e:
        await query.edit_message_text(text="❌ Произошла ошибка при отправке заявки. Попробуйте позже.")
        print(f"Ошибка отправки сообщения: {e}")

def main() -> None:
    """Запуск бота."""
    application = Application.builder().token(TOKEN).build()

    application.add_handler(CommandHandler("start", start))
    application.add_handler(CallbackQueryHandler(button_handler))

    print("Бот запущен...")
    application.run_polling()

if __name__ == "__main__":
    main()
